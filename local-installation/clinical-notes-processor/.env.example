# Copy this file to .env and fill in the values:  cp .env.example .env

# Ollama server, reachable FROM the clinical-api container.
# On a Linux server, use the Docker bridge gateway IP (usually 172.17.0.1 — confirm
# with:  ip -4 addr show docker0).
OLLAMA_HOST=http://172.17.0.1:11434

# Answering model (must be pulled in Ollama:  ollama pull qwen3:8b).
CLINICAL_OLLAMA_MODEL=qwen3:8b

# Folder containing the patient notes (one subfolder per patient), relative to this directory.
CLINICAL_NOTES_HOST_DIR=./notes

# Random session secret for the web UI. Generate one with:  openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGEME

# Optional: pin a specific published image version (otherwise the default in
# docker-compose.yml is used).
# CLINICAL_IMAGE=harbor.honeur.org/honeur/clinical-notes-processor:0.1.0
